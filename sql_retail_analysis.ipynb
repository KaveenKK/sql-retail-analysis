    "---\n",
    "## 4. SQL Analysis\n",
    "\n",
    "### Helper function\n",
    "We use a helper that runs a SQL query from an external file and returns a pandas DataFrame — a common pattern in professional data work."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def query(filename, label=''):\n",
    "    \"\"\"Reads SQL from a file, runs it, and returns a DataFrame. Optionally print results.\"\"\"\n",
    "    with open(f\"sql_queries/{filename}\", \"r\") as file:\n",
    "        sql = file.read()\n",
    "        \n",
    "    df = pd.read_sql_query(sql, conn)\n",
    "    if label:\n",
    "        print(f'=== {label} ===')\n",
    "        print(df.to_string(index=False))\n",
    "        print()\n",
    "    return df"
   ]
  },
